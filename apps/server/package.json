{
  "name": "@web-video/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pm2 start ../../ecosystem.config.cjs --only web-video-server --no-daemon",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:watch": "tsc -p tsconfig.json && node dist/index.js",
    "pm2:start": "pm2 start ../../ecosystem.config.cjs --only web-video-server",
    "pm2:stop": "pm2 stop web-video-server",
    "pm2:restart": "pm2 restart web-video-server",
    "pm2:logs": "pm2 logs web-video-server"
  },
  "dependencies": {
    "@web-video/shared": "workspace:*",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^13.1.0",
    "koa": "^2.16.1",
    "koa-body": "^6.0.1",
    "koa-static": "^5.0.0"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa__cors": "^5.0.0",
    "@types/koa-static": "^4.0.4",
    "@types/node": "^22.10.1",
    "pm2": "^5.4.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
